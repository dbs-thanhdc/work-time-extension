{
  "manifest_version": 3,
  "name": "Work Time Calculator",
  "version": "1.0.0",
  "description": "Tính ngày công và tổng giờ làm việc từ dữ liệu clipboard",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Work Time Calculator"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "clipboardRead",
    "storage"
  ]
}
